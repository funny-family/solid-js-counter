{
  "name": "solid-js-counter",
  "private": false,
  "version": "1.0.1",
  "description": "",
  "author": "funny-family <https://github.com/funny-family>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/funny-family/solid-js-counter.git"
  },
  "homepage": "https://github.com/funny-family/solid-js-counter#readme",
  "bugs": {
    "url": "https://github.com/funny-family/solid-js-counter/issues"
  },
  "license": "MIT",
  "keywords": [
    "solid",
    "solid-js",
    "solid-js-counter",
    "counter"
  ],
  "type": "module",
  "types": "./dist/types/index.d.ts",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugins/with-increment-decrement": {
      "import": "./dist/plugins/with-increment-decrement/index.js",
      "types": "./dist/plugins/with-increment-decrement/index.d.ts"
    },
    "./plugins/with-limits": {
      "import": "./dist/plugins/with-limits/index.js",
      "types": "./dist/plugins/with-limits/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "concurrently \"rm -rf ./dist\" \"pnpm build:watch\"",
    "vite:build": "vite build",
    "build": "./scripts/build.sh",
    "build:watch": "vite build --watch",
    "release": "release-it",
    "publish": "pnpm build && pnpm release",
    "rollup:build": "rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript"
  },
  "devDependencies": {
    "@rollup/plugin-multi-entry": "^6.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^20.14.15",
    "concurrently": "^8.2.2",
    "release-it": "^16.3.0",
    "rollup": "^4.44.2",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.4.2",
    "vite": "^4.5.3",
    "vite-dts": "^1.0.4",
    "vite-plugin-babel": "^1.3.2",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-solid": "^2.10.2"
  },
  "peerDependencies": {
    "solid-js": "^1.8.21"
  }
}
